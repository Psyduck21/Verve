{
  "name": "Verve",
  "private": true,
  "version": "0.1.0",
  "description": "Verve — Your Day, In Focus. AI-powered scheduler for web and mobile.",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@verve/web",
    "dev:mobile": "turbo run dev --filter=@verve/mobile",
    "dev:api": "turbo run dev --filter=@verve/backend",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@verve/db",
    "db:migrate": "turbo run db:migrate --filter=@verve/db",
    "db:studio": "turbo run db:studio --filter=@verve/db",
    "clean": "turbo run clean && rm -rf node_modules",
    "test:perf:load": "artillery run performance-tests/load_test.yml -o performance-tests/reports/load_report.json",
    "test:perf:stress": "artillery run performance-tests/stress_test.yml -o performance-tests/reports/stress_report.json",
    "test:perf:spike": "artillery run performance-tests/spike_test.yml -o performance-tests/reports/spike_report.json",
    "test:perf:dau": "artillery run performance-tests/dau_test.yml -o performance-tests/reports/dau_report.json",
    "test:perf:regression": "artillery run performance-tests/regression_test.yml -o performance-tests/reports/regression_report.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.3.0",
    "turbo": "^2.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "overrides": {
    "react-native-reanimated": "3.19.5"
  }
}
