# ── Focal Backend Environment Variables ────────────────────

# Server
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Supabase (Admin - NEVER expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# AI Provider
OPENROUTER_API_KEY=your-openrouter-api-key

# Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# PowerSync - RSA private key in PEM format
# Generate with: openssl genrsa -out private.pem 2048
POWERSYNC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
your-rsa-private-key-here
-----END PRIVATE KEY-----"

# Monitoring
SENTRY_DSN=your-sentry-dsn

# CORS - Chrome Extension IDs (comma-separated)
ALLOWED_EXTENSION_IDS=extension-id-1,extension-id-2
