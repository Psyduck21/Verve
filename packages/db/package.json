{
  "name": "@verve/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema and migrations for Focal's PostgreSQL database",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate":  "drizzle-kit migrate",
    "db:push":     "drizzle-kit push",
    "db:studio":   "drizzle-kit studio",
    "typecheck":   "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.0",
    "@verve/shared": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
